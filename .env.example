# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
# For production, use bcrypt hash: ADMIN_PASSWORD_HASH=$2a$10$...

# Telegram Bots (for file storage)
TELEGRAM_BOT_TOKEN_1=your_bot_token_1
TELEGRAM_BOT_TOKEN_2=your_bot_token_2
TELEGRAM_BOT_TOKEN_3=your_bot_token_3
TELEGRAM_CHANNEL_ID=-1003810443754
NEXT_PUBLIC_TELEGRAM_CHANNEL_ID=-1003810443754

# UploadThing (optional)
UPLOADTHING_SECRET=your_uploadthing_secret
UPLOADTHING_APP_ID=your_uploadthing_app_id

# OAuth Credentials (replace with your own credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
